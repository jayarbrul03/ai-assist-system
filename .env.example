# Next / Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (MUST be AU region: ap-southeast-2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# OAuth: enable Google (or others) in Supabase Dashboard → Authentication → Providers.
# URL config: Site URL = your app origin; Redirect URLs must allow
#   <origin>/api/auth/callback  (e.g. http://localhost:3000/api/auth/callback)

# Anthropic
ANTHROPIC_API_KEY=

# Voyage (embeddings)
VOYAGE_API_KEY=

# Resend
RESEND_API_KEY=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
